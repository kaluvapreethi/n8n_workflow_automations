    {
      "parameters": {
        "jsCode": "const items = $input.first().json;\n\nconst texts = items.text || [];\nconst senders = items.senders || [];\nconst subjects = items.subjects || [];\nconst dates = items.dates || [];\nconst threadIds = items.threadIds || []; // Grab the aggregated thread IDs\n\nlet structuredEmailDump = \"\";\n\nfor (let i = 0; i < texts.length; i++) {\n  // Construct the direct Gmail thread link\n  const emailLink = threadIds[i] ? `https://mail.google.com/mail/u/0/#inbox/${threadIds[i]}` : \"Link unavailable\";\n\n  structuredEmailDump += `=== EMAIL #${i + 1} ===\\n`;\n  structuredEmailDump += `FROM: ${senders[i] || 'Unknown Sender'}\\n`;\n  structuredEmailDump += `SUBJECT: ${subjects[i] || 'No Subject'}\\n`;\n  structuredEmailDump += `DATE: ${dates[i] || 'Unknown Date'}\\n`;\n  structuredEmailDump += `LINK TO EMAIL: ${emailLink}\\n`; // Injected here for the LLM\n  \n  let body = texts[i] || \"\";\n  body = body.replace(/View image:.*$/gm, \"\");\n  body = body.replace(/Caption:.*$/gm, \"\");\n  body = body.replace(/https?:\\/\\/\\S+/g, \"\");\n  body = body.replace(/\\n{3,}/g, \"\\n\\n\");\n  \n  structuredEmailDump += `BODY:\\n${body.trim()}\\n`;\n  structuredEmailDump += `====================\\n\\n`;\n}\n\nreturn [\n  {\n    json: {\n      formattedEmailsTranscript: structuredEmailDump\n    }\n  }\n];"
      },
