        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen2.5:7b\",\n  \"prompt\": {{ JSON.stringify(\n    \"Summarize these emails into a daily digest. If there is a new feature, explain what was missing before and what is new now. Also explain using Feynman's technique. The summary should be interactive making someone want to read.\\n\\n\" +\n    \"CRITICAL: Use proper Markdown spacing. Separate every metadata field with a fresh new line so it doesn't get bunched up.\\n\\n\" +\n    \"Format each email summary EXACTLY like this template:\\n\\n\" +\n    \"### Email #[Number] Summary\\n\" +\n    \"**Sender:** [Sender Name]\\n\" +\n    \"**Subject:** [Subject Text]\\n\" +\n    \"**Link to Email:** [Click Here to View Email]([URL]) -THIS FIELD IS IMPORTANT\\n\\n\" +\n    \"**Summary:**\\n\" +\n    \"[2-3 sentence summary using Feynman's technique here]\\n\\n\" +\n    \"**Key Points:**\\n\" +\n    \"- Point 1\\n\" +\n    \"- Point 2\\n\" +\n    \"--- \\n\\n\" + // Adds a clean horizontal separating line between emails\n    \"Email content:\\n\" + $json.formattedEmailsTranscript + \"\\n\\n\"\n  ) }},\n  \"stream\": false\n}",
        "options": {}
      },
